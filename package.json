{
  "name": "agent-research-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Playwright-driven MCP server for scholarly search providers.",
  "bin": {
    "agent-research-mcp": "./dist/server/index.js"
  },
  "scripts": {
